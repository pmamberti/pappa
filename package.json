{
  "name": "pappa",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "check:functions": "node --check 'functions/api/[[path]].js'",
    "d1:apply": "wrangler d1 execute pappa --remote --file=schema.sql",
    "d1:local:apply": "wrangler d1 execute pappa --local --persist-to .wrangler/state/v3 --file=schema.sql",
    "d1:local:migrate:auth": "wrangler d1 execute pappa --local --persist-to .wrangler/state/v3 --file=migrations/0001-auth.sql",
    "d1:local:seed": "wrangler d1 execute pappa --local --persist-to .wrangler/state/v3 --file=seed.example.sql",
    "d1:migrate:auth": "wrangler d1 execute pappa --remote --file=migrations/0001-auth.sql",
    "invite:sql": "node scripts/make-invite-token.mjs",
    "dev": "wrangler pages dev . --persist-to .wrangler/state/v3",
    "deploy": "wrangler pages deploy ."
  },
  "devDependencies": {
    "wrangler": "^4.92.0"
  }
}
